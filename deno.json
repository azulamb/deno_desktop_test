{
  "tasks": {
    "build": "deno desktop --backend cef --allow-read --allow-write main.ts",
    "start": "./dist/laufey.exe --runtime ./dist/dist.dll"
  },
  "desktop": {
    "app": {
      "name": "Deno desktop test",
      "identifier": "com.example.ddt",
      "icons": {
        "windows": "./docs/favicon.ico"
      }
    },
    "backend": "cef",
    "output": {
      "windows": "./dist"
    },
    "release": { "baseUrl": "https://updates.example.com" },
    "errorReporting": { "url": "https://errors.example.com/report" }
  }
}